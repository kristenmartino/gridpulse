# WattCast v2 — Environment Variables
# Copy to .env and fill in your values

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# TTL auto-computed as 2x scoring interval. Override here if needed:
# REDIS_FORECAST_TTL=7200

# Postgres
DATABASE_URL=postgresql://wattcast:wattcast_dev@localhost:5432/wattcast

# External APIs
EIA_API_KEY=your_eia_api_key_here
# Get one free at: https://www.eia.gov/opendata/register.php

# Model
MODEL_PATH=models/wattcast_xgb_latest.joblib

# ─── Pipeline Cadence ──────────────────────────────
# Scoring runs hourly (matches EIA/Open-Meteo hourly data cadence).
# Training runs daily (models retrained with latest full day of data).
# 5 min scoring: auto-enables fast_mode (XGBoost only, skips Prophet/ARIMA).
# <1 min: not supported by Airflow — swap to Kafka Streams/Flink.
SCORING_INTERVAL_MINUTES=60

# ─── Training Cadence ──────────────────────────────
# Models retrain daily. Adding 24 new hours to a 365-day training window
# produces negligible weight changes.
TRAINING_INTERVAL_HOURS=24

# ─── Model Persistence ─────────────────────────────
# Trained models persist to disk via joblib. Inference loads from disk.
MODEL_ARTIFACT_DIR=models/artifacts
MODEL_MAX_AGE_HOURS=48
MODEL_KEEP_SNAPSHOTS=3
