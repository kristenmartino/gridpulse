# NextEra Energy Demand Forecasting Dashboard
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === REQUIRED ===
# EIA API key (free): https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# === ENVIRONMENT (J1 — Environment Config Matrix) ===
# Determines defaults for all settings below.
# Values: development | staging | production
ENVIRONMENT=development

# === OPTIONAL (env-specific defaults shown) ===
# Override any value regardless of ENVIRONMENT.
#
# ┌──────────────────────┬────────────┬───────────┬────────────┐
# │ Setting              │ dev        │ staging   │ production │
# ├──────────────────────┼────────────┼───────────┼────────────┤
# │ LOG_LEVEL            │ DEBUG      │ INFO      │ WARNING    │
# │ CACHE_TTL_SECONDS    │ 21600 (6h) │ 7200 (2h) │ 3600 (1h)  │
# │ USE_DEMO_DATA        │ true       │ false     │ false      │
# │ ENABLE_PROFILING     │ true       │ false     │ false      │
# │ GUNICORN_WORKERS     │ 1          │ 2         │ 2          │
# │ MIN_INSTANCES        │ 0          │ 0         │ 1          │
# │ MAX_INSTANCES        │ 1          │ 2         │ 4          │
# └──────────────────────┴────────────┴───────────┴────────────┘

LOG_LEVEL=DEBUG
CACHE_TTL_SECONDS=21600
USE_DEMO_DATA=true
ENABLE_PROFILING=true
GUNICORN_WORKERS=1

# Server port (Cloud Run expects 8080)
PORT=8080

# Cache database path
CACHE_DB_PATH=cache.db

# Model storage directory
MODEL_DIR=trained_models

# Model refresh interval in seconds (default: 24 hours)
MODEL_REFRESH_INTERVAL=86400

# === GCS PERSISTENCE (Parquet fallback) ===
# Disabled by default in development. Enable for GCS testing:
# GCS_ENABLED=true
# GCS_BUCKET_NAME=nextera-portfolio-energy-cache
# GCS_PATH_PREFIX=cache

# === API KEY MANAGEMENT (D3) ===
# Development:  Set EIA_API_KEY above
# Staging:      Set as Cloud Run env var
# Production:   Use GCP Secret Manager:
#   gcloud secrets create eia-api-key --data-file=key.txt
#   gcloud secrets versions add eia-api-key --data-file=key.txt  (rotation)
#   Cloud Run config: --set-secrets=EIA_API_KEY=eia-api-key:latest
